{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyKmsKeyPolicyTamperingOrgWide",
      "Effect": "Deny",
      "Action": [
        "kms:PutKeyPolicy",
        "kms:ScheduleKeyDeletion",
        "kms:DisableKey",
        "kms:CreateGrant",
        "kms:RetireGrant",
        "kms:RevokeGrant"
      ],
      "Resource": "arn:aws:kms:*:123456789012:key/*",
      "Condition": {
        "ArnNotLike": {
          "aws:PrincipalArn": [
            "arn:aws:iam::123456789012:role/KmsKeyAdmin",
            "arn:aws:sts::123456789012:assumed-role/KmsKeyAdmin/*"
          ]
        }
      }
    },
    {
      "Sid": "DenyDisablingCloudTrail",
      "Effect": "Deny",
      "Action": [
        "cloudtrail:StopLogging",
        "cloudtrail:DeleteTrail",
        "cloudtrail:UpdateTrail",
        "cloudtrail:PutEventSelectors"
      ],
      "Resource": "*"
    },
    {
      "Sid": "DenyRootPrincipalExceptRecoveryAndBilling",
      "Effect": "Deny",
      "NotAction": [
        "aws-portal:*",
        "billing:*",
        "ce:*",
        "consoleapp:*",
        "iam:GetAccountSummary",
        "iam:ListAccount*",
        "iam:GetAccountPasswordPolicy",
        "iam:ChangePassword",
        "sso:*",
        "sso-directory:*",
        "support:*",
        "kms:PutKeyPolicy",
        "kms:DescribeKey",
        "kms:GetKeyPolicy",
        "organizations:DescribeOrganization"
      ],
      "Resource": "*",
      "Condition": {
        "ArnLike": {
          "aws:PrincipalArn": "arn:aws:iam::123456789012:root"
        }
      }
    }
  ]
}
